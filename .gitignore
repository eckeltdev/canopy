/target
# Defensive: a stray per-crate target dir (e.g. an agent running a one-off build)
# should never be committed even though the workspace shares the root /target.
**/target/
**/*.rs.bk
*.pdb
.DS_Store

# Rendered output artifacts (examples write these; default path is the crate dir)
*.ppm

# Workflow agent worktrees (harness scratch)
/.claude/worktrees/

# Deep-dive agent scratch (distillations with machine-specific paths)
/.context/

# Nested example build dir + lockfile noise
/examples/full/demo/target/

# WPT runner output
wpt-report.txt
